FORM incluir_produto.

  "-----------------------------------------------------
  " 1. Declaração da variável local: uma estrutura que representa 1 linha da tabela interna gt_produtos
  "-----------------------------------------------------
  DATA: ls_produto TYPE ty_produto.

  "-----------------------------------------------------
  " 2. Ler 1 produto da tabela interna (lista de produtos do fornecedor)
  "-----------------------------------------------------
  READ TABLE gt_produtos INTO ls_produto INDEX 1. " Pega o 1° produto da tabela e coloca em ls_produto

  "-----------------------------------------------------
  " 3. Verifica se a leitura (READ TABLE) funcionou
  "-----------------------------------------------------
  IF sy-subrc <> 0.
    MESSAGE 'Selecione um produto.' TYPE 'E'.
  ENDIF.

  "-----------------------------------------------------
  " 4. Limpa a estrutura do carrinho de compras
  "-----------------------------------------------------
  CLEAR gs_carrinho. "-> evita lixo de dados antigos

  "-----------------------------------------------------
  " 5. Transforma um produto em um item de pedido de compra
  "-----------------------------------------------------
  gs_carrinho-nome       = ls_produto-nome.
  gs_carrinho-preco      = ls_produto-preco.
  gs_carrinho-quantidade = p_qtd. "?

  "-----------------------------------------------------
  " 6. Calcula o total do item
  "-----------------------------------------------------
  gs_carrinho-total_item = gs_carrinho-quantidade * gs_carrinho-preco.

  "-----------------------------------------------------
  " 7. Adiciona ao carrinho
  "-----------------------------------------------------
  APPEND gs_carrinho TO gt_carrinho.

  "-----------------------------------------------------
  " 8. Atualiza o orçamento total do pedido de compras
  "-----------------------------------------------------
  PERFORM calcular_total.

ENDFORM.

FORM calcular_total.
  "-----------------------------------------------------
  " 1. O total começa zerado
  "-----------------------------------------------------
  gv_total = 0.

  "-----------------------------------------------------
  " 2. Percorre todo o carrinho de compras para calcular o total
  "-----------------------------------------------------
  LOOP AT gt_carrinho INTO gs_carrinho.
    gv_total = gv_total + gs_carrinho-total_item.
  ENDLOOP.

ENDFORM.

FORM confirmar_compra.

  "Obs.: não precisa calcular_total porque esse valor
  " já foi calculado ao adicionar produto no carrinho (on_double_click),
  " ao editar a quantidade de produto no carrinho (on_data_changed [editar] e on_data_changed_finished [fim da edição]) e
  " ao excluir produto do carrinho de compras,
  " então já temos o valor do gv_total pronto.

  "-----------------------------------------------------
  " 1. Pega o valor do saldo diretamente do banco de dados
  "-----------------------------------------------------
  PERFORM obter_saldo.

  "-----------------------------------------------------
  " 2. Verifica se tem saldo suficiente para pagar pelo pedido de compras
  "-----------------------------------------------------
  IF gv_total > gv_saldo.
    MESSAGE 'Saldo insuficiente para essa compra. Ajuste o pedido.' TYPE 'E'.
    RETURN. "Permite ao usuário voltar a acessar o pedido de compras de onde parou
  ENDIF.

  "-----------------------------------------------------
  " 3. Atualiza o estoque após a finalização das compras
  "-----------------------------------------------------
  LOOP AT gt_carrinho INTO gs_carrinho.

    UPDATE z35produtos_est
    SET quantidade = quantidade + gs_carrinho-quantidade
    WHERE nome = gs_carrinho-nome.

    "-----------------------------------------------------
    " 4. Verifica se deu tudo certo ao atualizar os estoques
    "-----------------------------------------------------
    IF sy-subrc <> 0.
      MESSAGE |Erro ao atualizar produto { gs_carrinho-nome }| TYPE 'E'.
    ENDIF.

  ENDLOOP.

  "-----------------------------------------------------
  " 5. Atualiza o saldo no banco de dados
  "-----------------------------------------------------
  gv_saldo = gv_saldo - gv_total.

  UPDATE z34recursos_fin
    SET saldo = gv_saldo
    WHERE id_fin = 1.

  COMMIT WORK.

  "-----------------------------------------------------
  " 6. Atualiza o saldo na tela
  "-----------------------------------------------------
  v_saldo = gv_saldo.

  MESSAGE 'Compra realizada com sucesso!' TYPE 'S'.

  CLEAR gt_carrinho.

ENDFORM.

