FORM cadastrar_produto.
  "-----------------------------------------------------
  " 1. Verificar preenchimento de campos obrigatórios
  "-----------------------------------------------------
  IF p_prod  IS INITIAL OR
     p_qtd   IS INITIAL OR
     p_cus   IS INITIAL OR
     p_prec  IS INITIAL OR
     p_e_min IS INITIAL OR
     p_e_max IS INITIAL.
    MESSAGE 'Informe nome, quantidade, custo e preço e limites de estoque do produto para cadastrar' TYPE 'E'.
  ENDIF.
  "-----------------------------------------------------
  " 2. Regra de negócio: não permitir venda com prejuízo
  "-----------------------------------------------------
  IF p_cus >= p_prec.
    MESSAGE 'O preço deve ser maior que o custo do produto.' TYPE 'E'.
  ENDIF.

  "-----------------------------------------------------
  " 3. Gerar ID automático
  "-----------------------------------------------------
  " Forma antiga e com possível bug no caso de uso simultâneo de 2 ou mais usuários:
*  DATA lv_id TYPE i.
*  SELECT MAX( id_produto ) INTO @lv_id FROM z34produtos_est.
*    lv_id = lv_id + 1.

  " Forma melhorada padrão SAP: (Fonte: Copilot + https://youtu.be/SmreMbaPAX4?si=9zLqsh7yVYiGr0Js )
  DATA lv_id TYPE z35produtos_est-id_produto.
  CALL FUNCTION 'NUMBER_GET_NEXT'
    EXPORTING
      nr_range_nr             = '01'
      object                  = 'Z35PROD_ID' "Nome do objeto de intervalo que criei na SNRO
    IMPORTING
      number                  = lv_id
    EXCEPTIONS
      interval_not_found      = 1
      number_range_not_intern = 2
      object_not_found        = 3
      quantity_is_0           = 4
      quantity_is_not_1       = 5
      interval_overflow       = 6
      suffer_overflow         = 7
      OTHERS                  = 8.

  IF sy-subrc = 0.
    MESSAGE |Número gerado: { lV_id }| TYPE 'S'.
  ELSE.
    MESSAGE |Erro ao gerar o número ( { sy-subrc } )| TYPE 'S' DISPLAY LIKE 'E'.
  ENDIF.
  "-----------------------------------------------------
  " 4. Cadastar os dados
  "-----------------------------------------------------
  " Inserir produto
  z35produtos_est-id_produto = lv_id.
  z35produtos_est-nome       = p_prod.
  z35produtos_est-quantidade = p_qtd.
  z35produtos_est-custo      = p_cus.
  z35produtos_est-preco      = p_prec.
  z35produtos_est-est_min    = p_e_min.
  z35produtos_est-est_max    = p_e_max.

  "-----------------------------------------------------
  " 5. Gravar no banco
  "-----------------------------------------------------
  INSERT z35produtos_est.
  LEAVE TO LIST-PROCESSING.
  "-----------------------------------------------------
  " 6. Verificar se deu certo a gravação no banco
  "-----------------------------------------------------
  IF sy-subrc <> 0.
    ROLLBACK WORK. " Cancela todas as instruções OpenSQL que modificam dados
    MESSAGE 'Erro ao cadastrar o produto.' TYPE 'E'.
  ENDIF.
  "-----------------------------------------------------
  " 7. Feedback ao usuário
  "-----------------------------------------------------
  COMMIT WORK. " Confirma todas as alterações na base de dados
  CLEAR: p_prod, p_qtd, p_cus, p_prec, p_inve, p_sac, p_e_min, p_e_max.
  MESSAGE 'O produto foi cadastrado com sucesso!' TYPE 'S'.

ENDFORM.

FORM obter_saldo.
  "-----------------------------------------------------
  " 1. Buscar o saldo atual no banco
  "-----------------------------------------------------
  SELECT SINGLE saldo
    INTO gv_saldo
  FROM z34recursos_fin
  WHERE id_fin = 1.

  "-----------------------------------------------------
  " 2. Verificar se encontrou o registro
  "-----------------------------------------------------
  IF sy-subrc <> 0.
    MESSAGE 'Erro ao obter o saldo financeiro' TYPE 'E'.
  ENDIF.

ENDFORM.

FORM comprar_produto.

  "-----------------------------------------------------
  " 1. Verificar preenchimento de campos obrigatórios
  "-----------------------------------------------------
  IF p_prod IS INITIAL.
    MESSAGE 'Informe o nome do produto' TYPE 'E'.
  ENDIF.
  IF p_qtd IS INITIAL.
    MESSAGE 'Informe quantidade de produtos que deseja comprar' TYPE 'E'.
  ENDIF.

  "-----------------------------------------------------
  " 2. Declaração de variáveis locais
  "-----------------------------------------------------
  DATA: ls_produto TYPE z35produtos_est,
        lv_custo   TYPE p LENGTH 15 DECIMALS 2.

  "-----------------------------------------------------
  " 3. Buscar o produto no banco
  "-----------------------------------------------------
  SELECT  SINGLE *
    INTO ls_produto
  FROM z35produtos_est
  WHERE nome = p_prod.

  IF sy-subrc <> 0.
    MESSAGE 'Esse produto não foi cadastrado' TYPE 'E'.
  ENDIF.

  "-----------------------------------------------------
  " 4. Calcular o custo total
  "-----------------------------------------------------
  lv_custo = p_qtd * ls_produto-custo.

  "-----------------------------------------------------
  " 5. Verificar se o saldo é suficiente para a compra
  "-----------------------------------------------------
  PERFORM obter_saldo.

  IF lv_custo > gv_saldo.
    MESSAGE 'Saldo insuficiente' TYPE 'E'.
  ENDIF.

  "-----------------------------------------------------
  " 6. Atualizar os dados
  "-----------------------------------------------------
  ls_produto-quantidade = ls_produto-quantidade + p_qtd.
  gv_saldo = gv_saldo - lv_custo.

  "-----------------------------------------------------
  " 7. Atualizar o banco de dados
  "-----------------------------------------------------
  UPDATE z35produtos_est
  SET quantidade = @ls_produto-quantidade
  WHERE id_produto = @ls_produto-id_produto.

  IF sy-subrc <> 0.
    ROLLBACK WORK. " Cancela todas as instruções OpenSQL que modificam dados
    MESSAGE 'Erro ao atualizar o estoque.' TYPE 'E'.
  ENDIF.

  UPDATE z34recursos_fin
  SET saldo = @gv_saldo
  WHERE id_fin = 1.

  IF sy-subrc <> 0.
    ROLLBACK WORK. " Cancela todas as instruções OpenSQL que modificam dados
    MESSAGE 'Erro ao atualizar o saldo.' TYPE 'E'.
  ENDIF.

  "-----------------------------------------------------
  " 8. Feedback ao usuário
  "-----------------------------------------------------
  COMMIT WORK. " Confirma todas as alterações na base de dados
  PERFORM atualizar_saldo_na_tela.
  CLEAR: p_prod, p_qtd, p_cus, p_prec, p_inve, p_sac.
  MESSAGE 'Venda realizada com sucesso!' TYPE 'S'.

ENDFORM.

FORM vender_produto.
  "-----------------------------------------------------
  " 1. Verificar preenchimento de campos obrigatórios
  "-----------------------------------------------------
  IF p_prod IS INITIAL.
    MESSAGE 'Informe o nome do produto' TYPE 'E'.
  ENDIF.
  IF p_qtd IS INITIAL.
    MESSAGE 'Informe quantidade de produtos que deseja vender' TYPE 'E'.
  ENDIF.
  "-----------------------------------------------------
  " 2. Declaração de variáveis locais
  "-----------------------------------------------------
  DATA: ls_produto TYPE z35produtos_est,
        lv_lucro   TYPE p LENGTH 15 DECIMALS 2.

  "-----------------------------------------------------
  " 3. Buscar o produto no banco
  "-----------------------------------------------------
  SELECT SINGLE *
    INTO ls_produto
  FROM z35produtos_est
  WHERE nome = p_prod.

  IF sy-subrc <> 0.
    MESSAGE 'Esse produto não foi cadastrado' TYPE 'E'.
  ENDIF.

  "-----------------------------------------------------
  " 4. Verificar se há estoque suficiente
  "-----------------------------------------------------
  IF ls_produto-quantidade < p_qtd.
    MESSAGE 'Estoque insuficiente' TYPE 'E'.
  ENDIF.

  "-----------------------------------------------------
  " 5. Calcular o lucro bruto
  "-----------------------------------------------------
  lv_lucro = p_qtd * ls_produto-preco.

  "-----------------------------------------------------
  " 6. Obter o saldo atual
  "-----------------------------------------------------
  PERFORM obter_saldo.

  "-----------------------------------------------------
  " 7. Atualizar os dados
  "-----------------------------------------------------
  ls_produto-quantidade = ls_produto-quantidade - p_qtd.
  gv_saldo = gv_saldo + lv_lucro.

  "-----------------------------------------------------
  " 8. Atualizar o banco de dados
  "-----------------------------------------------------
  UPDATE z35produtos_est
  SET quantidade = @ls_produto-quantidade
  WHERE id_produto = @ls_produto-id_produto.

  IF sy-subrc <> 0.
    ROLLBACK WORK. " Cancela todas as instruções OpenSQL que modificam dados
    MESSAGE 'Erro ao atualizar o estoque.' TYPE 'E'.
  ENDIF.

  UPDATE z34recursos_fin
  SET saldo = @gv_saldo
  WHERE id_fin = 1.

  IF sy-subrc <> 0.
    ROLLBACK WORK. " Cancela todas as instruções OpenSQL que modificam dados
    MESSAGE 'Erro ao atualizar o saldo.' TYPE 'E'.
  ENDIF.

  "-----------------------------------------------------
  " 9. Feedback ao usuário
  "-----------------------------------------------------
  COMMIT WORK. " Confirma todas as alterações na base de dados
  PERFORM atualizar_saldo_na_tela.
  CLEAR:p_prod, p_qtd, p_cus, p_prec, p_inve, p_sac.
  MESSAGE 'Venda realizada com sucesso!' TYPE 'S'.

ENDFORM.

