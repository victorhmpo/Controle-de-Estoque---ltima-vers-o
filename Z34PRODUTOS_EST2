FORM atualizar_limites.

  "-----------------------------------------------------
  " 1. Verificar preenchimento de campos obrigatórios
  "-----------------------------------------------------
  IF p_prod IS INITIAL.
    MESSAGE 'Informe o nome do produto antes de continuar.' TYPE 'E'.
  ENDIF.

  IF p_e_min IS INITIAL AND p_e_max IS INITIAL.
    MESSAGE 'Informe o novo limite mínimo ou máximo de estoque para atualizar.' TYPE 'E'.
  ENDIF.
  "-----------------------------------------------------
  " 2. Declaração de variável local
  "-----------------------------------------------------
  DATA ls_produto TYPE z35produtos_est.

  "-----------------------------------------------------
  " 3. Ver se o produto está cadastrado no banco de dados
  "-----------------------------------------------------
  SELECT SINGLE *
    INTO ls_produto
  FROM z35produtos_est
  WHERE nome = p_prod.

  IF sy-subrc <> 0.
    ROLLBACK WORK. " Confirma todas as alterações na base de dados
    MESSAGE 'Esse produto não foi cadastrado.' TYPE 'E'.
  ENDIF.

  "-----------------------------------------------------
  " 4. Regra de negócio: limite máximo maior que limite mínimo
  "-----------------------------------------------------
  IF p_e_min IS NOT INITIAL AND p_e_max IS NOT INITIAL AND p_e_min >= p_e_max.
    MESSAGE 'O limite mínimo deve ser menor que o limite máximo.' TYPE 'E'.
  ENDIF.

  "-----------------------------------------------------
  " 5. Regra de negócio: limite mínimo >= 1
  "-----------------------------------------------------
  IF p_e_min IS NOT INITIAL AND p_e_min < 1.
    MESSAGE 'O limite mínimo ´não pode ser zerado nem negativo.' TYPE 'E'.
  ENDIF.
  "-----------------------------------------------------
  " 6. Atualizar o banco de dados
  "-----------------------------------------------------

  DATA ls_set TYPE string. "ls_set guarda o comando SQL que será montado dinamicamente

  " Verificar se o campo do estoque mínimo foi preenchido
  IF p_e_min IS NOT INITIAL.
    ls_set = |est_min = { p_e_min }|.
  ENDIF.

  " Verificar se o campo do estoque máximo foi preenchido
  IF p_e_max IS NOT INITIAL.
    IF ls_set IS INITIAL.
      ls_set = |est_max = { p_e_max }|.
    ELSE.
      ls_set = |{ ls_set }, est_max = { p_e_max }|.
    ENDIF.
  ENDIF.

  IF ls_set IS NOT INITIAL.
    UPDATE z35produtos_est
    SET (ls_set) "ls = est_min = x se est_min IS NOT INITIAL e/ou est_max = y se est_max IS NOT INITIAL
    WHERE id_produto = @ls_produto-id_produto.

    "-----------------------------------------------------
    " 6. Verificar se a gravação no banco deu certo
    "-----------------------------------------------------
    IF sy-subrc <> 0.
      ROLLBACK WORK.
      MESSAGE 'Erro ao atualizar o(s) limite(s) de estoque.' TYPE 'E'.
    ENDIF.
  ENDIF.

  "-----------------------------------------------------
  " 7. Feedback ao usuário
  "-----------------------------------------------------
  COMMIT WORK. " Confirma todas as alterações na base de dados
  MESSAGE: 'Limite(s) de estoque atualizado(s) com sucesso!' TYPE 'S'.
  CLEAR: p_prod, p_qtd, p_cus, p_prec, p_inve, p_sac, p_e_min, p_e_max.

ENDFORM.

