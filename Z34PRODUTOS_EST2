FORM atualizar_caption_popup.

  DATA lv_caption TYPE c LENGTH 100.

  IF gv_tipo_operacao = 'C'.
    lv_caption = |Pedido de compra - Total: { gv_total }|.
  ELSEIF gv_tipo_operacao = 'V'.
    lv_caption = |Pedido de venda - Total: { gv_total }|.
  ENDIF.

  IF go_popup IS BOUND. "se a janela popup estiver aberta (pra não dar DUMP)
    go_popup->set_caption( "vá até o método set_caption do objeto go_popup
      EXPORTING
        caption = lv_caption "envia o texto para o método
    ).
  ENDIF.

ENDFORM.

FORM criar_popup.

  CREATE OBJECT go_popup
    EXPORTING
      width  = 1000
      height = 250
      top    = 50
      left   = 80.

  "para garantir que o objeto handler existe
  IF go_handler IS NOT BOUND. "se não existir
    CREATE OBJECT go_handler. "cria
  ENDIF.
  SET HANDLER go_handler->on_close FOR go_popup. "usa o método do objeto handler

ENDFORM.

FORM criar_splitter
  " Divide a janela popup em 2 containers:
  "   . Esquerdo: lista de produtos
  "   . Direito:  carrinho de compras
  CHANGING co_cont_prod TYPE REF TO cl_gui_container
           co_cont_carr TYPE REF TO cl_gui_container.

  DATA lo_splitter TYPE REF TO cl_gui_splitter_container.

  CREATE OBJECT lo_splitter
    EXPORTING
      parent  = go_popup
      rows    = 1
      columns = 2.

  co_cont_prod = lo_splitter->get_container( row = 1 column = 1 ).
  co_cont_carr = lo_splitter->get_container( row = 1 column = 2 ).

ENDFORM.

FORM criar_alvs
  USING    io_cont_prod TYPE REF TO cl_gui_container
           io_cont_carr TYPE REF TO cl_gui_container
  CHANGING co_alv_prod  TYPE REF TO cl_gui_alv_grid
           co_alv_carr  TYPE REF TO cl_gui_alv_grid.

  CREATE OBJECT co_alv_prod
    EXPORTING
      i_parent = io_cont_prod.

  CREATE OBJECT co_alv_carr
    EXPORTING
      i_parent = io_cont_carr.

  " guarda referência global
  go_alv_carr = co_alv_carr.

  "registra edição
  co_alv_carr->register_edit_event(
    EXPORTING i_event_id = cl_gui_alv_grid=>mc_evt_modified ).

ENDFORM.

FORM carregar_produtos.

  CLEAR gt_produtos.

  SELECT nome, preco, quantidade
    INTO CORRESPONDING FIELDS OF TABLE @gt_produtos
    FROM z35produtos_est.

  SORT gt_produtos BY nome.

ENDFORM.

FORM exibir_alv
  USING io_alv      TYPE REF TO cl_gui_alv_grid
        it_outtab   TYPE STANDARD TABLE
        it_fieldcat TYPE lvc_t_fcat.

  DATA ls_layout TYPE lvc_s_layo.

  io_alv->set_table_for_first_display(
    EXPORTING is_layout = ls_layout
    CHANGING
      it_outtab       = it_outtab
      it_fieldcatalog = it_fieldcat ).

ENDFORM.

FORM registrar_eventos
  USING io_alv_prod TYPE REF TO cl_gui_alv_grid
        io_alv_carr TYPE REF TO cl_gui_alv_grid.

  DATA lo_event TYPE REF TO lcl_alv_event.
  CREATE OBJECT lo_event.

  SET HANDLER lo_event->on_double_click          FOR io_alv_prod. "adicionar item de compra ao carrinho
  SET HANDLER lo_event->on_data_changed          FOR io_alv_carr. "edição possível de quantidade de itens
  SET HANDLER lo_event->on_data_changed_finished FOR io_alv_carr. "atualiza dados com base na quantidade de itens alterada
  SET HANDLER lo_event->on_toolbar               FOR io_alv_carr. "botão de confirmação existe na ALV
  SET HANDLER lo_event->on_user_command          FOR io_alv_carr. "botão de confirmação funciona na ALV

ENDFORM.
