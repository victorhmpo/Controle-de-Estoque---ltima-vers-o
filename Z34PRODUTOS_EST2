      p_text = 'Estoque máximo'
      p_edit = space
      p_outputlen = 20
    CHANGING
      pt_fieldcat = gt_fieldcat ).

  zcl_alv_helper=>adicionar_field_catalog(
    EXPORTING
      p_field = 'SINALIZADOR'
      p_text = 'Sinalizador'
      p_edit = space
    CHANGING
      pt_fieldcat = gt_fieldcat ).

  "-----------------------------------------------------
  " 6. Exibir ALV com os dados e o field catalog
  "-----------------------------------------------------
  CALL METHOD go_alv->set_table_for_first_display
    EXPORTING
      i_structure_name = '' " Vazio porque usamos estrutura local
    CHANGING
      it_outtab        = gt_produtos  " Dados a serem exibidos
      it_fieldcatalog  = gt_fieldcat. " Estrutura das colunas

ENDFORM.

