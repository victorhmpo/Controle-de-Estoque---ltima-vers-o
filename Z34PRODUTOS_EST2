      p_text = 'Estoque atual'
      p_edit = space
    CHANGING
      pt_fieldcat = gt_fieldcat ).

  zcl_alv_helper=>adicionar_field_catalog(
    EXPORTING
      p_field = 'PRECO'
      p_text = 'Preço'
      p_edit = space
    CHANGING
      pt_fieldcat = gt_fieldcat ).

  zcl_alv_helper=>adicionar_field_catalog(
    EXPORTING
      p_field = 'CUSTO'
      p_text = 'Custo'
      p_edit = space
    CHANGING
      pt_fieldcat = gt_fieldcat ).

  zcl_alv_helper=>adicionar_field_catalog(
    EXPORTING
      p_field = 'MARGEM'
      p_text = 'Margem de lucro (%)'
      p_edit = space
    CHANGING
      pt_fieldcat = gt_fieldcat ).

  zcl_alv_helper=>adicionar_field_catalog(
    EXPORTING
      p_field = 'ESTOQUE_MINIMO'
      p_text = 'Estoque mínimo'
      p_edit = space
      p_outputlen = 20
    CHANGING
