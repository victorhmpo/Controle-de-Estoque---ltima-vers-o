" Classe de Serviço:
CLASS zcl_pedido_service DEFINITION.
  PUBLIC SECTION.
    METHODS:
      confirmar_compra
        IMPORTING it_carrinho TYPE STANDARD TABLE,
      confirmar_venda
        IMPORTING it_carrinho TYPE STANDARD TABLE.
ENDCLASS.

CLASS zcl_pedido_service IMPLEMENTATION.

  METHOD confirmar_compra.

    DATA: lv_saldo TYPE z34recursos_fin-saldo,
          ls_item  TYPE ty_item_compra.

    PERFORM obter_saldo.

    IF gv_total > gv_saldo.
      MESSAGE 'Saldo insuficiente.' TYPE 'E'.
    ENDIF.

    LOOP AT it_carrinho INTO ls_item.

      UPDATE z35produtos_est
        SET quantidade = quantidade + ls_item-quantidade
        WHERE nome = ls_item-nome.

    ENDLOOP.

    gv_saldo = gv_saldo - gv_total.

    UPDATE z34recursos_fin
      SET saldo = gv_saldo
      WHERE id_fin = 1.

    COMMIT WORK.

  ENDMETHOD.

  METHOD confirmar_venda.

    DATA: ls_item    TYPE ty_item_compra,
          ls_produto TYPE z35produtos_est.

    " Validação de estoque
    LOOP AT it_carrinho INTO ls_item.

      SELECT SINGLE *
        INTO ls_produto
        FROM z35produtos_est
        WHERE nome = ls_item-nome.

      IF ls_produto-quantidade < ls_item-quantidade.
        MESSAGE |Estoque insuficiente para { ls_item-nome }| TYPE 'E'.
      ENDIF.

    ENDLOOP.

    " Atualização de estoque (diminui)
    LOOP AT it_carrinho INTO ls_item.

      UPDATE z35produtos_est
        SET quantidade = quantidade - ls_item-quantidade "estoque reduz a quantidade vendida
        WHERE nome = ls_item-nome.

    ENDLOOP.

    "Aualização de saldo (aumenta)
    PERFORM obter_saldo.

    gv_saldo = gv_saldo + gv_total.

    UPDATE z34recursos_fin
      SET saldo = gv_saldo
      WHERE id_fin = 1.

    COMMIT WORK.

  ENDMETHOD.

ENDCLASS.

" Classe para permitir eventos em janela popup de pedido de compra / eventos do ALV
CLASS lcl_alv_event DEFINITION.
  PUBLIC SECTION.
    METHODS on_double_click FOR EVENT double_click OF cl_gui_alv_grid "para adicionar item de compra
      IMPORTING e_row e_column.
    METHODS on_data_changed "permite alterar quantidade no carrinho de compras
      FOR EVENT data_changed OF cl_gui_alv_grid
      IMPORTING er_data_changed.
    METHODS on_data_changed_finished "recalcula total e título de janela após alteração do usuário no carrinho de compras
        FOR EVENT data_changed_finished OF cl_gui_alv_grid.
    METHODS on_toolbar "faz o botão de confirmar pedido de compra existir
      FOR EVENT toolbar OF cl_gui_alv_grid
      IMPORTING e_object e_interactive.
    METHODS on_user_command "faz o botão de confirmar pedido de compra funcionar
      FOR EVENT user_command OF cl_gui_alv_grid
      IMPORTING e_ucomm.
ENDCLASS.

CLASS lcl_alv_event IMPLEMENTATION.

  METHOD on_double_click. "-> Adicionar item de compra

    DATA ls_produto TYPE ty_produto.

    READ TABLE gt_produtos INTO ls_produto INDEX e_row-index.

    IF sy-subrc <> 0.
      RETURN.
    ENDIF.

    CLEAR gs_carrinho.

    "-----------------------------------------------------
    " 1. Adiciona na tabela
    "-----------------------------------------------------
    gs_carrinho-nome = ls_produto-nome.
    gs_carrinho-preco = ls_produto-preco.
    gs_carrinho-quantidade = 1. "quantidade inicial padrão (editável)
    "-----------------------------------------------------
    " 2. Calcula o total
    "-----------------------------------------------------
    gs_carrinho-total_item = gs_carrinho-quantidade * gs_carrinho-preco.
    "-----------------------------------------------------
    " 3. Adiciona ao carrinho de compras
    "-----------------------------------------------------
    APPEND gs_carrinho TO gt_carrinho.
    "-----------------------------------------------------
    " 4. Recalcula total geral
    "-----------------------------------------------------
    PERFORM calcular_total.
    "-----------------------------------------------------
    " 5. Manda o ALV atualizar
    "-----------------------------------------------------
    IF go_alv_carr IS BOUND.
      CALL METHOD go_alv_carr->refresh_table_display( ).
    ENDIF.
    "-----------------------------------------------------
    " 6. Manda o caption atualizar (o título da janela popup)
    "-----------------------------------------------------
    PERFORM atualizar_caption_popup.
    "-----------------------------------------------------
    " 7. Mostra o total na tela
    "-----------------------------------------------------
    MESSAGE | Total atual: { gv_total }| TYPE 'S'.

  ENDMETHOD.

  METHOD on_data_changed. "-> permite alterar quantidade no carrinho de compras - e recalcula custo

    DATA ls_mod  TYPE lvc_s_modi.
    DATA ls_item TYPE ty_item_compra.

    LOOP AT er_data_changed->mt_mod_cells INTO ls_mod.

      "Pega a linha editada
      READ TABLE gt_carrinho INTO ls_item INDEX ls_mod-row_id.

      IF sy-subrc <> 0.
        CONTINUE. " Pula para a próxima iteração do LOOP
      ENDIF.

      "Atualizar quantidade
      IF ls_mod-fieldname = 'QUANTIDADE'.

        ls_item-quantidade = ls_mod-value+0. "+0 porque value é tipo string, e +0 força a conversão numérica

        "Recalcular o total do item
        ls_item-total_item = ls_item-quantidade * ls_item-preco.

        "Atualizar na tabela
        MODIFY gt_carrinho
        FROM ls_item
        INDEX ls_mod-row_id.

        "Atualizar o campo "Total" da tabela do carrinho de compras na ALV
        CALL METHOD er_data_changed->modify_cell
          EXPORTING
            i_row_id    = ls_mod-row_id
            i_fieldname = 'TOTAL_ITEM'
            i_value     = ls_item-total_item.

      ENDIF.

    ENDLOOP.

    "Recalcular total geral
    PERFORM calcular_total.

    "Força atualização visual limpa no campo "Total" da tabela do carrinho de compras na ALV
    CALL METHOD cl_gui_cfw=>flush.

    IF go_popup IS BOUND.
      "Atualizar título
      PERFORM atualizar_caption_popup.
    ENDIF.
  ENDMETHOD.

  METHOD on_data_changed_finished. "-> recalcula total e título de janela após alteração do usuário no carrinho de compras

    "Recalcular total geral
    PERFORM calcular_total.

    "Atualizar título
    IF go_popup IS BOUND.
      PERFORM atualizar_caption_popup.
    ENDIF.

  ENDMETHOD.

  METHOD on_toolbar. "-> faz o botão de confirmar (o pedido de compra) existir

    DATA ls_button TYPE stb_button.

    CLEAR ls_button.

    ls_button-function  = 'CONFIRM'.
    IF gv_tipo_operacao = 'C'.
      ls_button-text      = 'Confirmar pedido de compras'.
      ls_button-quickinfo = 'Confirmar pedido de compras.'.
    ELSEIF gv_tipo_operacao = 'V'.
      ls_button-text      = 'Confirmar pedido de vendas'.
      ls_button-quickinfo = 'Confirmar pedido de vendas.'.
    ENDIF.
    ls_button-icon      = icon_system_save.

    APPEND ls_button TO e_object->mt_toolbar.

  ENDMETHOD.

  METHOD on_user_command. "-> faz o botão de confirmar (o pedido de compra/venda) funcionar

    DATA lo_service TYPE REF TO zcl_pedido_service.

    CREATE OBJECT lo_service.

    CASE e_ucomm.

      WHEN 'CONFIRM'.

        IF gv_tipo_operacao = 'C'.
          lo_service->confirmar_compra( gt_carrinho ).

        ELSEIF gv_tipo_operacao = 'V'.
          lo_service->confirmar_venda( gt_carrinho ).

        ENDIF.

        PERFORM atualizar_saldo_na_tela.

        IF go_popup IS BOUND.            " se o popup existir
          CALL METHOD go_popup->free.    " fecha a janela popup
          CALL METHOD cl_gui_cfw=>flush. " atualiza a interface imediatamente
        ENDIF.

        LEAVE TO SCREEN sy-dynnr. " atualiza os campos (no caso, o do saldo) imediatamente

    ENDCASE.

  ENDMETHOD.

ENDCLASS.

