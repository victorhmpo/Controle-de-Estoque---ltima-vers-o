FORM ver_estoque_popup.
  "-----------------------------------------------------
  " 1. Criar popup (janela modal)
  "-----------------------------------------------------
  PERFORM criar_popup.

  "-----------------------------------------------------
  " 2. Para poder fechar o popup ao clicar no X
  "-----------------------------------------------------
  IF go_handler IS NOT BOUND.
    CREATE OBJECT go_handler.
  ENDIF.
  SET HANDLER go_handler->on_close FOR go_popup.

  "-----------------------------------------------------
  " 3. Para criar ALV dentro do popup
  "-----------------------------------------------------
  CREATE OBJECT go_alv
    EXPORTING
      i_parent = go_popup. " Define que o ALV será exibido dentro do popup

  DATA ls_produto TYPE ty_produto.

  CLEAR gt_produtos.

  SELECT nome, quantidade, preco, custo, est_min AS estoque_minimo, est_max AS estoque_maximo
  INTO CORRESPONDING FIELDS OF TABLE @gt_produtos
  FROM z35produtos_est.

  FIELD-SYMBOLS: <fs_produto> TYPE ty_produto.

  LOOP AT gt_produtos ASSIGNING <fs_produto>.
    "-----------------------------------------------------
    " 4. Calcular a margem de lucro:
    "-----------------------------------------------------

    " Evitar divisão por 0
    IF <fs_produto>-preco > 0.
      <fs_produto>-margem = ( ( <fs_produto>-preco - <fs_produto>-custo ) / <fs_produto>-preco ) * 100.
    ELSE.
      <fs_produto>-margem = 0.
    ENDIF.

    " Calcular o sinalizador de estoque:
    IF <fs_produto>-quantidade < <fs_produto>-estoque_minimo.
      <fs_produto>-sinalizador = icon_red_light.
    ELSEIF <fs_produto>-quantidade <= <fs_produto>-estoque_maximo.
      <fs_produto>-sinalizador = icon_yellow_light.
    ELSE.
      <fs_produto>-sinalizador = icon_green_light.
    ENDIF.

  ENDLOOP.

  "-----------------------------------------------------
  " 5. Montar manualmente o Field Catalog
  "-----------------------------------------------------

  " Como usamos uma estrutura local (ty_produto), o ALV não consegue gerar automaticamente
  CLEAR gt_fieldcat.

  zcl_alv_helper=>adicionar_field_catalog(
    EXPORTING
      p_field = 'NOME'
